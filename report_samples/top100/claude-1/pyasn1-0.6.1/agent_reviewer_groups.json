        "codeql_raw_query": "/**\n * @name Missing validation on decoded length values\n * @description Length values decoded from input should be validated before use\n * @kind problem\n * @problem.severity warning\n * @id py/asn1-missing-length-validation\n * @tags security\n *        external/cwe/cwe-129\n */\n\nimport python\n\nfrom Assign assign, Name target\nwhere\n  (target.getId() = \"length\" or target.getId().matches(\"%Length\")) and\n  assign.getATarget() = target and\n  assign.getScope().getEnclosingModule().getName() = \"pyasn1.codec.ber.decoder\" and\n  not exists(Compare cmp | \n    cmp.getASubExpression*() = target and\n    cmp.getScope() = assign.getScope()\n  )\nselect assign, \"Length value assigned without subsequent validation check.\"",
