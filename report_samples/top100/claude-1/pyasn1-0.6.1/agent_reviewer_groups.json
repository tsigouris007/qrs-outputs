        "codeql_raw_query": "/**\n * @name Integer overflow in length calculations\n * @description Arithmetic operations on length values without overflow checks could lead to integer overflow\n * @kind problem\n * @problem.severity warning\n * @id py/asn1-integer-overflow\n * @tags security\n *        external/cwe/cwe-190\n */\n\nimport python\nimport semmle.python.dataflow.new.DataFlow\n\nfrom BinaryExpr binop, Name lengthVar\nwhere\n  (binop.getOp() instanceof Add or binop.getOp() instanceof Mult or binop.getOp() instanceof Sub) and\n  (lengthVar.getId() = \"length\" or lengthVar.getId() = \"size\" or lengthVar.getId().matches(\"%Length%\")) and\n  (binop.getLeft() = lengthVar or binop.getRight() = lengthVar or\n   binop.getLeft().(Name).getId().matches(\"%length%\") or binop.getRight().(Name).getId().matches(\"%length%\")) and\n  binop.getLocation().getFile().getRelativePath().matches(\"%decoder%\")\nselect binop, \"Arithmetic operation on length value without overflow check could lead to integer overflow.\"",
