      "codeql_query_uuid": "20251229115528",
      "codeql_raw_query": "/**\n * @name Unbounded recursion in ASN.1 decoder\n * @description Recursive decoding without depth limits can lead to stack overflow DoS\n * @kind problem\n * @problem.severity error\n * @id py/asn1-unbounded-recursion\n * @tags security\n *        external/cwe/cwe-674\n */\n\nimport python\nimport semmle.python.ApiGraphs\n\nfrom Function func, FunctionExpr recursiveCall\nwhere\n  func.getEnclosingModule().getName().matches(\"pyasn1.codec%\") and\n  func.getName().matches(\"%decode%\") and\n  recursiveCall.getScope() = func and\n  recursiveCall.getInnerScope() = func and\n  // Check if the function calls itself\n  exists(Call c | \n    c.getScope() = func and\n    c.getFunc().(Name).getId() = func.getName()\n  )\nselect func, \"Potentially unbounded recursive decoder function without depth limit checks.\"\n",
      "hypothesis": "Check for unbounded recursion in ASN.1 decoders that could lead to stack overflow DoS attacks",
      "severity": "high",
      "cwe_ids": [
        "cwe-674"
      ],
      "results_count": 0,
      "results": []
    },
