      "codeql_raw_query": "/**\n * @name Unbounded allocation based on decoded length\n * @description Memory allocation based on decoded length values without size limits can lead to DoS\n * @kind problem\n * @problem.severity warning\n * @id py/asn1-decoder-unbounded-allocation\n * @tags security\n *        external/cwe/cwe-400\n *        external/cwe/cwe-770\n */\n\nimport python\nimport semmle.python.dataflow.new.DataFlow\nimport semmle.python.ApiGraphs\n\n// Find calls to bytearray() or similar allocation functions in decoder files\nfrom DataFlow::CallCfgNode call, string filename\nwhere\n  (\n    call = API::builtin(\"bytearray\").getACall() or\n    call = API::builtin(\"bytes\").getACall() or\n    call = API::builtin(\"list\").getACall()\n  ) and\n  filename = call.getLocation().getFile().getBaseName() and\n  filename.matches(\"%decoder%\") and\n  // Check if there's a size argument\n  exists(call.getArg(0))\nselect call, \"Memory allocation in decoder at \" + filename + \" that may use untrusted length without validation.\"\n",
