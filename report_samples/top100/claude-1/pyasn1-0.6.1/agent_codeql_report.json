      "codeql_raw_query": "/**\n * @name Recursive decoder call without depth limit\n * @description Recursive decoder calls without proper depth limits can lead to stack exhaustion\n * @kind problem\n * @problem.severity warning\n * @id py/asn1-recursive-decoder\n * @tags security\n *        external/cwe/cwe-674\n */\n\nimport python\n\nfrom Function decoder, Call recursiveCall, Name callee\nwhere\n  decoder.getName().matches(\"%decode%\") and\n  recursiveCall.getScope() = decoder and\n  recursiveCall.getFunc() = callee and\n  callee.getId() = decoder.getName()\nselect recursiveCall, \"Recursive decoder call in \" + decoder.getName() + \" could lead to stack exhaustion with malicious input.\"",
