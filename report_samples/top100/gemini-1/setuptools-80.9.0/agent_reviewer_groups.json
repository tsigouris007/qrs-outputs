        "codeql_query_uuid": "20260101151423",
        "codeql_raw_query": "/**\n * @name Potential Command Injection (Broad)\n * @description Detects subprocess calls with non-literal arguments, which might be risky.\n * @kind problem\n * @problem.severity warning\n * @id py/broad-command-injection\n * @tags security\n *       external/cwe/cwe-078\n */\n\nimport python\nimport semmle.python.dataflow.new.DataFlow\nimport semmle.python.ApiGraphs\n\nfrom DataFlow::CallCfgNode call, DataFlow::Node arg\nwhere\n  (\n    call = API::moduleImport(\"subprocess\").getMember([\"call\", \"check_call\", \"check_output\", \"run\", \"Popen\"]).getACall() or\n    call = API::moduleImport(\"os\").getMember([\"system\", \"popen\"]).getACall()\n  )\n  and\n  (\n    // Check first argument for non-literal\n    (\n      arg = call.getArg(0) and\n      not arg.asExpr() instanceof StringLiteral and\n      not arg.asExpr() instanceof List\n    )\n    or\n    // For shell=True, check if the command is non-literal\n    (\n        call.getArgByName(\"shell\").asExpr() instanceof True and\n        arg = call.getArg(0) and\n        not arg.asExpr() instanceof StringLiteral\n    )\n  )\nselect call, \"Potential command execution with non-literal argument.\"",
