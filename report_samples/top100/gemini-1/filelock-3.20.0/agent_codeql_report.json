      "codeql_raw_query": "/**\n * @name Inspect os.open flags for O_EXCL\n * @description Checks if os.open is called with O_EXCL to ensure atomic file creation.\n * @kind problem\n * @problem.severity warning\n * @id py/inspect-os-open-excl\n * @tags security\n *       external/cwe/cwe-362\n */\n\nimport python\nimport semmle.python.dataflow.new.DataFlow\nimport semmle.python.ApiGraphs\n\nfrom DataFlow::CallCfgNode call, DataFlow::Node flagsArg, DataFlow::Node excl\nwhere\n  call = API::moduleImport(\"os\").getMember(\"open\").getACall() and\n  flagsArg = call.getArg(1) and\n  excl = API::moduleImport(\"os\").getMember(\"O_EXCL\").asSource() and\n  not DataFlow::localFlow(excl, flagsArg)\nselect call, \"os.open called, verify if O_EXCL is included in flags (argument 1). O_EXCL source: \" + excl.toString()\n",
