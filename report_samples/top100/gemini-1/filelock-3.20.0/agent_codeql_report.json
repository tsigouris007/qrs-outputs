    {
      "codeql_query_uuid": "20251226122841",
      "codeql_raw_query": "/**\n * @name Insecure file permissions in os.open\n * @description Checks if os.open is called with insecure file permissions (e.g. world writable).\n * @kind problem\n * @problem.severity warning\n * @id py/insecure-os-open-mode\n * @tags security\n *       external/cwe/cwe-276\n *       external/cwe/cwe-732\n */\n\nimport python\nimport semmle.python.ApiGraphs\n\nfrom DataFlow::CallCfgNode call, DataFlow::Node modeArg, IntegerLiteral modeInt\nwhere\n  call = API::moduleImport(\"os\").getMember(\"open\").getACall() and\n  (\n    modeArg = call.getArg(2) or\n    modeArg = call.getArgByName(\"mode\")\n  ) and\n  modeArg.asExpr() = modeInt and\n  (modeInt.getValue().bitAnd(63) != 0)\nselect call, \"File created with potentially insecure permissions: \" + modeInt.getValue().toString()",
