        "codeql_raw_query": "/**\n * @name Locate from_buffer usages in OpenSSL backend\n * @description Find all calls to from_buffer in cryptography's OpenSSL backend to inspect buffer handling.\n * @kind problem\n * @problem.severity warning\n * @id py/cryptography-from-buffer-locations\n * @tags security\n *       external/cwe/cwe-754\n */\n\nimport python\n\nfrom Call call, Attribute attr\nwhere\n  call.getFunc() = attr and\n  attr.getAttr() = \"from_buffer\" and\n  call.getLocation().getFile().getRelativePath().matches(\"src/cryptography/hazmat/backends/openssl/%\")\nselect call, \"Call to from_buffer in OpenSSL backend for manual review of buffer writability checks.\"\n",
