        "codeql_query_uuid": "20260118111301",
        "codeql_raw_query": "/**\n * @name Dangerous dynamic code execution in PyYAML\n * @description Find uses of eval, exec, compile, and __import__ in the yaml package\n * @kind problem\n * @problem.severity warning\n * @id py/pyyaml/dangerous-code-execution\n * @tags security\n *       external/cwe/cwe-094\n */\n\nimport python\n\npredicate isDangerousFunction(string name) {\n  name in [\"eval\", \"exec\", \"compile\", \"__import__\"]\n}\n\nfrom Call c, string funcName, File f\nwhere\n  f = c.getLocation().getFile() and\n  f.getRelativePath().regexpMatch(\"^(lib|lib3)/yaml/.*\") and\n  (\n    c.getFunc().(Name).getId() = funcName and isDangerousFunction(funcName)\n    or\n    c.getFunc().(Attribute).getName() = funcName and isDangerousFunction(funcName)\n  )\nselect c, \"Dangerous code execution function found: \" + funcName\n",
        "hypothesis": "PyYAML may use dynamic code execution primitives internally, which could be leveraged during YAML parsing or object construction.",
        "severity": "high",
