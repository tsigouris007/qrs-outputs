        "codeql_raw_query": "/**\n * @name PyYAML constructors using dynamic imports\n * @description Find uses of __import__ in yaml/constructor.py that may load arbitrary modules based on YAML content\n * @kind problem\n * @problem.severity error\n * @id py/pyyaml/dynamic-import-constructors\n * @tags security\n *       external/cwe/cwe-094\n *       external/cwe/cwe-502\n */\n\nimport python\n\nfrom Call c, File f\nwhere\n  f = c.getLocation().getFile() and\n  f.getRelativePath().regexpMatch(\"^(lib|lib3)/yaml/constructor.py\") and\n  c.getFunc().(Name).getId() = \"__import__\"\nselect c, \"Dynamic module import in PyYAML constructor; ensure this is not reachable from untrusted YAML input.\"\n",
