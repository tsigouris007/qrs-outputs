      "codeql_raw_query": "/**\n * @name AEAD operations with from_buffer without writeability checks\n * @description AEAD encrypt/decrypt operations that use from_buffer on output parameters without writeability validation\n * @kind problem\n * @problem.severity error\n * @id py/aead-buffer-writeability-check\n * @tags security\n *       external/cwe/cwe-754\n */\n\nimport python\n\nfrom Function func, Call fromBufferCall, Parameter param\nwhere\n  fromBufferCall.getFunc().(Attribute).getName() = \"from_buffer\" and\n  fromBufferCall.getScope() = func and\n  func.getLocation().getFile().getRelativePath().matches(\"%aead.py\") and\n  param = func.getAnArg() and\n  (func.getName().matches(\"%encrypt%\") or func.getName().matches(\"%decrypt%\"))\nselect fromBufferCall, \"AEAD operation in \" + func.getName() + \" uses from_buffer on parameter without writeability validation at line \" + fromBufferCall.getLocation().getStartLine().toString()",
