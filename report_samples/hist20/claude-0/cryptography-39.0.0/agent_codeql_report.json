      "codeql_raw_query": "/**\n * @name Buffer writeability validation in update_into methods\n * @description Checks if buffers created with from_buffer have writeability validation before write operations\n * @kind problem\n * @problem.severity error\n * @id py/missing-buffer-writeability-check\n * @tags security\n *       external/cwe/cwe-754\n */\n\nimport python\n\nfrom Function func, Call fromBufferCall, Expr bufferArg\nwhere\n  func.getName() = \"update_into\" and\n  fromBufferCall.getFunc().(Attribute).getName() = \"from_buffer\" and\n  fromBufferCall.getScope() = func and\n  bufferArg = fromBufferCall.getArg(0) and\n  // Check if there's no writeability check before the from_buffer call\n  not exists(Attribute attr |\n    attr.getObject() = bufferArg and\n    (attr.getName() = \"readonly\" or attr.getName() = \"writable\")\n  )\nselect fromBufferCall, \"Buffer created from parameter '\" + bufferArg.toString() + \"' without writeability validation before write operation in \" + func.getName()",
