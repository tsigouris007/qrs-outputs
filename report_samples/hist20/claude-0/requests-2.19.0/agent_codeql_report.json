    {
      "codeql_query_uuid": "20260118134312",
      "codeql_raw_query": "/**\n * @name Authorization header deletion in rebuild_auth\n * @description Find where Authorization header is deleted during redirects\n * @kind problem\n * @problem.severity warning\n * @id py/auth-header-deletion\n * @tags security\n *       redirect\n */\n\nimport python\n\nfrom Delete del, Subscript sub\nwhere\n  del.getATarget() = sub and\n  sub.getObject().(Attribute).getName() = \"headers\" and\n  sub.getIndex().(StrConst).getText() = \"Authorization\" and\n  del.getScope().(Function).getName() = \"rebuild_auth\"\nselect del, \"Authorization header deleted in rebuild_auth at line \" + del.getLocation().getStartLine().toString()",
