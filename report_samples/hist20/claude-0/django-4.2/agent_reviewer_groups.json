        "codeql_raw_query": "/**\n * @name Find all regex patterns in validators module\n * @description Identifies all regex pattern definitions in the validators module to analyze for ReDoS vulnerabilities\n * @kind problem\n * @problem.severity recommendation\n * @id py/find-validator-regex-patterns\n * @tags security\n *       regex\n *       validation\n */\n\nimport python\nimport semmle.python.ApiGraphs\n\nfrom Assign assign, Expr pattern\nwhere\n  assign.getScope().getEnclosingModule().getName() = \"django.core.validators\" and\n  (\n    // Direct re.compile calls\n    pattern = assign.getValue().(Call).getFunc().(Attribute) and\n    pattern.(Attribute).getObject().(Name).getId() = \"re\" and\n    pattern.(Attribute).getName() = \"compile\"\n    or\n    // String patterns assigned to variables\n    pattern = assign.getValue() and\n    pattern instanceof StrConst\n  )\nselect assign, \"Regex pattern definition in validators: \" + assign.getTarget(0).(Name).getId()",
