      {
        "codeql_query_uuid": "20260118122113",
        "codeql_raw_query": "/**\n * @name Potential CSRF via JSON body parsing without Content-Type validation\n * @description Async request handlers that parse JSON bodies without validating Content-Type header may be vulnerable to CSRF attacks\n * @kind problem\n * @problem.severity warning\n * @id py/csrf-json-body-no-content-type\n * @tags security\n *       external/cwe/cwe-352\n */\n\nimport python\n\nfrom Function f, Call bodyCall, Attribute attr\nwhere\n  f.isAsync() and\n  bodyCall.getScope() = f and\n  bodyCall.getFunc() = attr and\n  (\n    (attr.getName() = \"body\" and attr.getObject().(Name).getId() = \"request\") or\n    (attr.getName() = \"json\" and attr.getObject().(Name).getId() = \"request\")\n  ) and\n  not exists(Attribute headerAttr |\n    headerAttr.getScope() = f and\n    headerAttr.getName() = \"headers\" and\n    headerAttr.getObject().(Name).getId() = \"request\"\n  ) and\n  not f.getLocation().getFile().getRelativePath().matches(\"%tutorial%\") and\n  f.getLocation().getFile().getRelativePath().matches(\"%routing%\")\nselect bodyCall, \"Async function '\" + f.getName() + \"' parses request body without Content-Type validation, potentially vulnerable to CSRF\"\n",
        "hypothesis": "Async request handlers in routing.py parse JSON request bodies without validating Content-Type headers, which could allow CSRF attacks when combined with cookie-based authentication",
        "severity": "high",
        "cwe_ids": [
