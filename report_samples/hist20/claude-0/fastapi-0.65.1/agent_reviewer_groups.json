        "codeql_query_uuid": "20260118121936",
        "codeql_raw_query": "/**\n * @name Request body parsing without Content-Type validation\n * @description Finds request body or json parsing that may occur without prior Content-Type header validation\n * @kind problem\n * @problem.severity warning\n * @id py/request-body-no-content-type-check\n * @tags security\n *       csrf\n */\n\nimport python\n\nfrom Call call, Attribute attr, Function f\nwhere\n  call.getFunc() = attr and\n  (attr.getName() = \"json\" or attr.getName() = \"body\") and\n  attr.getObject().(Name).getId() = \"request\" and\n  f = call.getScope() and\n  not exists(Attribute headerAttr |\n    headerAttr.getObject().(Name).getId() = \"request\" and\n    headerAttr.getName() = \"headers\" and\n    headerAttr.getScope() = f\n  )\nselect call, \"Request body/json parsing in function '\" + f.getName() + \"' without apparent Content-Type header check\"\n",
        "hypothesis": "Request body parsing without Content-Type validation could allow CSRF attacks via JSON body parsing",
