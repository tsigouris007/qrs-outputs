def split_template_path(template: str) -> t.List[str]:
    pieces = []
    for piece in template.split("/"):
        if (
            os.path.sep in piece
            or (os.path.altsep and os.path.altsep in piece)
            or piece == os.path.pardir
        ):
            raise TemplateNotFound(template)
        elif piece and piece != ".":
            pieces.append(piece)
    return pieces
```

This checks:
1. If the piece contains os.path.sep (e.g., "\\" on Windows)
2. If the piece contains os.path.altsep (e.g., "/" on Windows, but "/" is the split character!)
3. If the piece equals os.path.pardir (i.e., "..")

