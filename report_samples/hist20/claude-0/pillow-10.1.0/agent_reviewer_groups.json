        "codeql_query_uuid": "20260118125025",
        "codeql_raw_query": "/**\n * @name Code injection via eval in ImageMath\n * @description Using eval with user-controlled input can lead to arbitrary code execution\n * @kind path-problem\n * @problem.severity error\n * @id py/imagemath-code-injection\n * @tags security\n *        external/cwe/cwe-094\n */\n\nimport python\nimport semmle.python.dataflow.new.DataFlow\nimport semmle.python.dataflow.new.TaintTracking\nimport semmle.python.dataflow.new.RemoteFlowSources\nimport semmle.python.ApiGraphs\n\nmodule CodeInjectionConfig implements DataFlow::ConfigSig {\n  predicate isSource(DataFlow::Node source) {\n    // Any parameter to a public function\n    source instanceof DataFlow::ParameterNode\n    or\n    // Remote flow sources\n    source instanceof RemoteFlowSource\n  }\n\n  predicate isSink(DataFlow::Node sink) {\n    // Argument to eval() or exec()\n    exists(DataFlow::CallCfgNode call |\n      call = API::builtin(\"eval\").getACall() or\n      call = API::builtin(\"exec\").getACall() |\n      sink = call.getArg(_)\n    )\n  }\n}\n\nmodule CodeInjectionFlow = TaintTracking::Global<CodeInjectionConfig>;\nimport CodeInjectionFlow::PathGraph\n\nfrom CodeInjectionFlow::PathNode source, CodeInjectionFlow::PathNode sink\nwhere CodeInjectionFlow::flowPath(source, sink)\nselect sink.getNode(), source, sink, \"Code injection from $@.\", source.getNode(), \"user-controlled input\"\n",
        "hypothesis": "User-controlled input flows to eval() or exec() calls, enabling arbitrary code execution",
        "severity": "critical",
