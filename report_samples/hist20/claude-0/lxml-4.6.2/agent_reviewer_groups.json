        "codeql_raw_query": "/**\n * @name Missing formaction attribute in URL sanitization lists\n * @description The HTML sanitizer does not include 'formaction' in its list of URL-containing attributes, allowing XSS via javascript: URLs in formaction attributes\n * @kind problem\n * @problem.severity error\n * @id py/missing-formaction-sanitization\n * @tags security\n *       external/cwe/cwe-079\n *       external/cwe/cwe-116\n */\n\nimport python\n\nfrom Assign assign, Name target, StrConst str\nwhere\n  // Find assignments to link_attrs or _tag_link_attrs dictionaries\n  assign.getATarget() = target and\n  (target.getId() = \"link_attrs\" or \n   target.getId() = \"_tag_link_attrs\" or\n   target.getId().matches(\"%link%attr%\")) and\n  // Find string constants in the assignment that are URL-related attributes\n  str.getEnclosingModule() = assign.getEnclosingModule() and\n  (str.getText() = \"action\" or \n   str.getText() = \"href\" or \n   str.getText() = \"src\") and\n  // Ensure this is in the HTML cleaning/sanitization code\n  assign.getLocation().getFile().getRelativePath().matches(\"%html%\")\nselect assign, \"URL attribute list '\" + target.getId() + \"' includes 'action' but is missing 'formaction', which can bypass XSS sanitization. The formaction attribute on buttons/inputs can override form action with javascript: URLs.\"\n",
