        "codeql_raw_query": "/**\n * @name Find attribute lists containing URL attributes\n * @description Finds list/set definitions that contain URL-related attributes like href, src, action\n * @kind problem\n * @problem.severity warning\n * @id py/find-url-attribute-lists\n * @tags security\n *       xss\n *       sanitization\n */\n\nimport python\n\npredicate isUrlAttribute(string attr) {\n  attr in [\"href\", \"src\", \"action\", \"formaction\", \"data\", \"poster\", \"background\", \"cite\", \"longdesc\"]\n}\n\nfrom Expr listExpr, StrConst attrStr, string attrValue, string location\nwhere\n  location = listExpr.getLocation().getFile().getRelativePath() and\n  location.matches(\"%lxml/html%\") and\n  (listExpr instanceof List or listExpr instanceof Set or listExpr instanceof Tuple) and\n  attrStr = listExpr.getASubExpression*() and\n  attrValue = attrStr.getText() and\n  isUrlAttribute(attrValue.replaceAll(\"\\\"\", \"\").replaceAll(\"'\", \"\"))\nselect listExpr, \"List/set containing URL attribute '\" + attrValue + \"' at \" + location + \":\" + listExpr.getLocation().getStartLine().toString()",
