        "codeql_query_uuid": "20260118114602",
        "codeql_raw_query": "/**\n * @name Content-Length parsing with int() in HTTP parser\n * @description Finds int() calls on Content-Length headers in http_parser.py without prior isdigit() validation\n * @kind problem\n * @problem.severity error\n * @id py/http-content-length-int-without-validation\n * @tags security\n *       external/cwe/cwe-444\n */\n\nimport python\nimport semmle.python.dataflow.new.DataFlow\nimport semmle.python.ApiGraphs\n\nfrom DataFlow::CallCfgNode intCall, DataFlow::Node arg\nwhere\n  intCall = API::builtin(\"int\").getACall() and\n  arg = intCall.getArg(0) and\n  // Only in http_parser.py file\n  intCall.getLocation().getFile().getBaseName() = \"http_parser.py\"\nselect intCall, \"Call to int() in HTTP parser that may parse Content-Length without validation\"\n",
        "hypothesis": "Content-Length header parsing in http_parser.py uses int() without validating that the value contains only ASCII digits, potentially accepting invalid formats like +256, -0, or 0_2e",
