        "codeql_raw_query": "/**\n * @name String strip operations in HTTP parser\n * @description Finds strip/lstrip/rstrip calls in HTTP parser that may violate RFC\n * @kind problem\n * @problem.severity error\n * @id py/http-parser-strip-operations\n * @tags security\n *       external/cwe/cwe-444\n */\n\nimport python\n\nfrom Call call, Attribute attr\nwhere\n  attr = call.getFunc() and\n  (attr.getName() = \"strip\" or attr.getName() = \"lstrip\" or attr.getName() = \"rstrip\") and\n  call.getLocation().getFile().getBaseName() = \"http_parser.py\"\nselect call, \"Strip operation '\" + attr.getName() + \"' in HTTP parser\"",
