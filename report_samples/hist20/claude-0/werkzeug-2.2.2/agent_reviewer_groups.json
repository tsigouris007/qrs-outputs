        "codeql_raw_query": "/**\n * @name Cookie name edge case handling\n * @description Find where cookie names are extracted and check for validation of empty or special character names\n * @kind problem\n * @problem.severity warning\n * @id py/cookie-name-edge-cases\n * @tags security\n *       cookies\n *       cwe-20\n */\n\nimport python\n\nfrom Call call, Attribute attr\nwhere \n  call.getFunc() = attr and\n  (\n    attr.getName() = \"strip\" or\n    attr.getName() = \"lstrip\" or\n    attr.getName() = \"startswith\"\n  ) and\n  exists(StrConst s | \n    s.getEnclosingModule().getName().matches(\"%internal%\") or\n    s.getEnclosingModule().getName().matches(\"%http%\")\n  ) and\n  call.getLocation().getFile().getBaseName().matches(\"%internal%\")\nselect call, \"Cookie name processing at: \" + call.getLocation().getFile().getBaseName() + \":\" + call.getLocation().getStartLine().toString()",
