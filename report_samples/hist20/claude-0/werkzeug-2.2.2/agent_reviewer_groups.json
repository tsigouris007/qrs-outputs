        "codeql_raw_query": "/**\n * @name Improper cookie name validation in parsing\n * @description Cookie parsing allows empty or invalid cookie names which can lead to security issues\n * @kind problem\n * @problem.severity warning\n * @id py/improper-cookie-name-validation\n * @tags security\n *       cookies\n *       cwe-20\n */\n\nimport python\n\nfrom StrConst regex, Call compileCall\nwhere\n  compileCall.getFunc().(Attribute).getName() = \"compile\" and\n  compileCall.getFunc().(Attribute).getObject().(Name).getId() = \"re\" and\n  regex = compileCall.getArg(0) and\n  (\n    regex.getText().matches(\"%(?P<key>%\") and\n    regex.getText().matches(\"%[^=;]+%\")\n  ) and\n  regex.getLocation().getFile().getBaseName() = \"_internal.py\"\nselect regex, \"Cookie parsing regex allows empty or invalid cookie names: \" + regex.getText().substring(0, 100)",
