        "codeql_query_uuid": "20260118115454",
        "codeql_raw_query": "/**\n * @name Directory traversal via path manipulation\n * @description User-controlled paths may allow directory traversal attacks\n * @kind path-problem\n * @problem.severity error\n * @id py/aiohttp-path-traversal\n * @tags security\n *       external/cwe/cwe-022\n */\n\nimport python\nimport semmle.python.dataflow.new.DataFlow\nimport semmle.python.dataflow.new.TaintTracking\nimport semmle.python.ApiGraphs\n\nmodule PathTraversalConfig implements DataFlow::ConfigSig {\n  predicate isSource(DataFlow::Node source) {\n    exists(DataFlow::AttrRead attr |\n      attr.getAttributeName() in [\"path\", \"raw_path\", \"rel_url\"] and\n      source = attr\n    )\n  }\n\n  predicate isSink(DataFlow::Node sink) {\n    exists(DataFlow::CallCfgNode call |\n      (\n        call = API::moduleImport(\"pathlib\").getMember(\"Path\").getACall() or\n        call = API::builtin(\"open\").getACall()\n      ) and\n      sink = call.getArg(_)\n    )\n  }\n}\n\nmodule PathTraversalFlow = TaintTracking::Global<PathTraversalConfig>;\nimport PathTraversalFlow::PathGraph\n\nfrom PathTraversalFlow::PathNode source, PathTraversalFlow::PathNode sink\nwhere PathTraversalFlow::flowPath(source, sink)\nselect sink.getNode(), source, sink, \"Potential path traversal from $@.\", source.getNode(), \"user-controlled path\"",
        "hypothesis": "User-controlled request paths flow to file system operations without proper validation, potentially allowing directory traversal attacks",
        "severity": "high",
        "cwe_ids": [
