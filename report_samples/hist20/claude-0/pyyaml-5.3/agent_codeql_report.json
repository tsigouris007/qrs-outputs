    {
      "codeql_query_uuid": "20260118133909",
      "codeql_raw_query": "/**\n * @name Unsafe YAML loader class definitions\n * @description Identifies YAML loader classes that inherit from dangerous constructors\n * @kind problem\n * @problem.severity error\n * @id py/yaml-unsafe-loader-classes\n * @tags security\n *       external/cwe/cwe-502\n */\n\nimport python\nimport semmle.python.ApiGraphs\n\nfrom Class cls\nwhere\n  cls.getName() in [\"Loader\", \"UnsafeLoader\", \"FullLoader\", \"DangerLoader\"] and\n  exists(ImportExpr imp | imp.getEnclosingModule() = cls.getEnclosingModule() |\n    imp.getImportedModuleName() = \"yaml\"\n  )\nselect cls, \"Unsafe YAML loader class: \" + cls.getName()",
      "hypothesis": "Find YAML loader classes that enable arbitrary Python object construction through dangerous constructors",
      "severity": "critical",
      "cwe_ids": [
        "cwe-502"
