      "codeql_raw_query": "/**\n * @name Dangerous Python object YAML tag handlers\n * @description Finds tag handlers that enable arbitrary Python object instantiation via python/object tags\n * @kind problem\n * @problem.severity error\n * @id py/yaml-python-object-tags\n * @tags security\n *       external/cwe/cwe-502\n */\n\nimport python\n\nfrom Call call, Attribute attr, StrConst tag\nwhere\n  attr = call.getFunc() and\n  (\n    attr.getName() = \"add_constructor\" or\n    attr.getName() = \"add_multi_constructor\"\n  ) and\n  tag = call.getArg(0) and\n  (\n    tag.getText().matches(\"%python/object%\") or\n    tag.getText().matches(\"%python/name%\") or\n    tag.getText().matches(\"%python/module%\")\n  )\nselect call, \"Dangerous YAML tag handler for Python objects: \" + tag.getText()",
