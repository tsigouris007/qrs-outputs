        "codeql_query_uuid": "20260118133427",
        "codeql_raw_query": "/**\n * @name Unsafe object construction from YAML\n * @description Finds calls to dangerous functions like eval, exec, compile, and __import__ that could enable code execution\n * @kind problem\n * @problem.severity error\n * @id py/yaml-dangerous-functions\n * @tags security\n *       external/cwe/cwe-094\n *       external/cwe/cwe-502\n */\n\nimport python\nimport semmle.python.ApiGraphs\n\nfrom DataFlow::CallCfgNode call, string funcName\nwhere\n  (\n    call = API::builtin([\"eval\", \"exec\", \"compile\", \"__import__\"]).getACall() and\n    funcName = call.getFunction().asExpr().(Name).getId()\n  )\nselect call, \"Dangerous code execution function found: \" + funcName\n",
        "hypothesis": "Find dangerous code execution functions (eval, exec, compile, __import__) that could enable arbitrary code execution during YAML parsing",
        "severity": "critical",
