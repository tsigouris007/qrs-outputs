      {
        "codeql_query_uuid": "20260118133627",
        "codeql_raw_query": "/**\n * @name Python object constructor implementations\n * @description Finds the implementation of dangerous constructor methods that instantiate Python objects\n * @kind problem\n * @problem.severity error\n * @id py/yaml-object-constructor-impl\n * @tags security\n *       external/cwe/cwe-502\n */\n\nimport python\n\nfrom Function func\nwhere\n  (\n    func.getName() = \"find_python_module\" or\n    func.getName() = \"find_python_name\" or\n    func.getName() = \"make_python_instance\" or\n    func.getName() = \"construct_python_name\" or\n    func.getName() = \"construct_python_module\" or\n    func.getName() = \"construct_python_object\" or\n    func.getName() = \"construct_python_object_apply\" or\n    func.getName() = \"construct_python_object_new\"\n  ) and\n  func.getEnclosingModule().getName().matches(\"%constructor%\")\nselect func, \"Dangerous constructor method: \" + func.getName()",
        "hypothesis": "Find the implementation methods that construct Python objects from YAML tags",
        "severity": "critical",
        "cwe_ids": [
          "cwe-502"
