        "codeql_raw_query": "/**\n * @name Find xmlattr filter function\n * @description Finds the xmlattr filter function definition in Jinja2\n * @kind problem\n * @problem.severity recommendation\n * @id py/find-xmlattr-filter\n * @tags security\n *       xml\n *       filters\n */\n\nimport python\n\nfrom Function f\nwhere \n  f.getName().toLowerCase().matches(\"%xmlattr%\")\nselect f, \"Function containing 'xmlattr' found: \" + f.getName() + \" in \" + f.getLocation().getFile().getBaseName()\n",
