        "codeql_query_uuid": "20260118122920",
        "codeql_raw_query": "/**\n * @name Attribute injection in xmlattr filter\n * @description The xmlattr filter may allow attribute injection through keys containing spaces or special characters\n * @kind problem\n * @problem.severity error\n * @id py/jinja2-xmlattr-injection\n * @tags security\n *       external/cwe/cwe-79\n *       external/cwe/cwe-116\n */\n\nimport python\n\nfrom Function f, Expr formatExpr\nwhere \n  f.getName() = \"do_xmlattr\" and\n  formatExpr.getScope() = f and\n  (\n    // Look for string formatting that constructs attributes\n    formatExpr instanceof BinaryExpr or\n    formatExpr.(Call).getFunc().(Attribute).getName() = \"format\" or\n    formatExpr.(Call).getFunc().(Name).getId() = \"Markup\"\n  )\nselect formatExpr, \"Potential attribute injection: xmlattr filter constructs HTML attributes at line \" + formatExpr.getLocation().getStartLine().toString() + \" without validating keys for spaces or special characters that could break out of attribute context\"\n",
        "hypothesis": "The xmlattr filter in Jinja2 may not properly validate attribute keys, allowing keys with spaces or special characters to break out of the attribute context and inject additional attributes or JavaScript event handlers, leading to XSS vulnerabilities",
        "severity": "high",
        "cwe_ids": [
