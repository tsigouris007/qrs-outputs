        "codeql_raw_query": "/**\n * @name Find numeric to datetime conversion without bounds checks\n * @description Identifies functions that convert numeric values to datetime/timedelta objects without proper bounds validation\n * @kind problem\n * @problem.severity error\n * @id py/unbounded-numeric-datetime-conversion\n * @tags security\n *       external/cwe/cwe-835\n *       external/cwe/cwe-400\n */\n\nimport python\nimport semmle.python.ApiGraphs\n\nfrom DataFlow::CallCfgNode call\nwhere\n  (\n    // timedelta construction calls\n    call = API::moduleImport(\"datetime\").getMember(\"timedelta\").getACall()\n    or\n    // datetime construction calls\n    call = API::moduleImport(\"datetime\").getMember(\"datetime\").getACall()\n    or\n    // date construction calls\n    call = API::moduleImport(\"datetime\").getMember(\"date\").getACall()\n    or\n    // time construction calls\n    call = API::moduleImport(\"datetime\").getMember(\"time\").getACall()\n  )\nselect call, \"Datetime/timedelta construction that may accept unbounded numeric values\"\n",
        "hypothesis": "Find all datetime/timedelta construction calls that could potentially accept unbounded numeric values including infinity",
