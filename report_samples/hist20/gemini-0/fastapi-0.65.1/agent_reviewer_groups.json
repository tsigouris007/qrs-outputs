        "codeql_raw_query": "/**\n * @name Dangerous function usage\n * @description Finds usage of eval, exec, or subprocess\n * @kind problem\n * @problem.severity error\n * @id py/dangerous-functions\n * @tags security\n *       dangerous-functions\n */\n\nimport python\nimport semmle.python.ApiGraphs\n\nfrom DataFlow::CallCfgNode call\nwhere\n  call = API::builtin([\"eval\", \"exec\"]).getACall()\n  or\n  call = API::moduleImport(\"subprocess\").getMember([\"call\", \"check_call\", \"check_output\", \"run\", \"Popen\"]).getACall()\n  or\n  call = API::moduleImport(\"os\").getMember([\"system\", \"popen\"]).getACall()\nselect call, \"Usage of dangerous function\"",
