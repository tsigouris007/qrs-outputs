        "codeql_query_uuid": "20260118164157",
        "codeql_raw_query": "/**\n * @name Unsafe Request Body Access\n * @description Detects potential unsafe access to request body (e.g. reading unlimited size)\n * @kind problem\n * @problem.severity warning\n * @id py/unsafe-request-body\n * @tags security\n *       external/cwe/cwe-400\n */\n\nimport python\nimport semmle.python.dataflow.new.DataFlow\n\nfrom DataFlow::CallCfgNode call, Attribute attr, Name name\nwhere\n  call.getFunction().asExpr() = attr\n  and attr.getObject() = name\n  and name.getId() = \"request\"\n  and attr.getAttr() in [\"json\", \"body\", \"stream\", \"form\"]\nselect call, \"Potential unsafe request body access.\"\n",
