      "codeql_raw_query": "/**\n * @name Analyze FileInput.value_from_datadict\n * @description Checks how FileInput.value_from_datadict handles file data\n * @kind problem\n * @problem.severity info\n * @id py/django-fileinput-value-from-datadict\n * @tags django\n *       file-upload\n */\n\nimport python\nimport semmle.python.ApiGraphs\n\nfrom Class c, Function f\nwhere\n  c.getName() = \"FileInput\"\n  and f = c.getAMethod()\n  and f.getName() = \"value_from_datadict\"\nselect f, \"FileInput.value_from_datadict implementation\"",
