      "codeql_raw_query": "/**\n * @name Analyze FileInput.value_from_datadict implementation\n * @description Checks if value_from_datadict uses get() or getlist() on the files dictionary\n * @kind problem\n * @problem.severity info\n * @id py/django-fileinput-implementation-analysis\n * @tags file-upload\n *       django\n */\n\nimport python\nimport semmle.python.ApiGraphs\n\nfrom Function f, Call c, Attribute a\nwhere\n  f.getName() = \"value_from_datadict\"\n  and f.getEnclosingModule().getName() = \"django.forms.widgets\"\n  and c.getScope() = f\n  and c.getFunc() = a\n  and (a.getName() = \"get\" or a.getName() = \"getlist\")\nselect c, \"Call to \" + a.getName() + \" in value_from_datadict\"\n",
