      "codeql_raw_query": "/**\n * @name Find Authorization header manipulation\n * @description Finds places where the 'Authorization' header is set or accessed, particularly in relation to redirects or history.\n * @kind problem\n * @problem.severity warning\n * @id py/requests-auth-header-manipulation\n * @tags security\n *       external/cwe/cwe-200\n */\n\nimport python\nimport semmle.python.dataflow.new.DataFlow\nimport semmle.python.ApiGraphs\n\nfrom DataFlow::Node node\nwhere\n  (\n    node.asExpr().(StrConst).getText() = \"Authorization\" or\n    node.asExpr().(StrConst).getText() = \"authorization\"\n  )\nselect node, \"Found usage of 'Authorization' string.\"",
