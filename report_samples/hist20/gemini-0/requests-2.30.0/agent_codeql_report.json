      "codeql_query_uuid": "20260118220800",
      "codeql_raw_query": "/**\n * @name Analyze rebuild_auth logic\n * @description Inspects rebuild_auth function for Authorization header removal logic\n * @kind problem\n * @problem.severity warning\n * @id py/analyze-rebuild-auth\n * @tags security\n *       authorization\n *       redirects\n */\n\nimport python\nimport semmle.python.ApiGraphs\n\nfrom Function f, Stmt s\nwhere \n  f.getName() = \"rebuild_auth\" and\n  s.getScope() = f and\n  (\n    exists(Delete d | d = s and d.contains(any(StrConst str | str.getText() = \"Authorization\"))) or\n    exists(Call c | c = s.(ExprStmt).getValue() and c.getFunc().(Attribute).getName() = \"pop\" and c.getArg(0).(StrConst).getText() = \"Authorization\")\n  )\nselect s, \"Found Authorization header manipulation in rebuild_auth\"",
