    {
      "codeql_query_uuid": "20260118220737",
      "codeql_raw_query": "/**\n * @name Analyze rebuild_auth logic\n * @description Checks how rebuild_auth handles Authorization header removal\n * @kind problem\n * @problem.severity warning\n * @id py/analyze-rebuild-auth\n * @tags security\n *       external/cwe/cwe-200\n */\n\nimport python\nimport semmle.python.dataflow.new.DataFlow\n\nfrom Function f, Call c\nwhere f.getName() = \"rebuild_auth\"\n  and c.getScope() = f\n  and (\n    c.getFunc().(Attribute).getName() = \"pop\" or\n    c.getFunc().(Attribute).getName() = \"__delitem__\"\n  )\n  and exists(StrConst s | s = c.getArg(0) and s.getText() = \"Authorization\")\nselect c, \"Found removal of Authorization header in rebuild_auth\"\n",
      "hypothesis": "rebuild_auth might improperly handle Authorization header removal during redirects",
      "severity": "high",
      "cwe_ids": [
        "CWE-200"
      ],
      "results_count": 0,
      "results": []
