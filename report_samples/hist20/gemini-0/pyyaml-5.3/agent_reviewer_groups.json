        "codeql_query_uuid": "20260118181708",
        "codeql_raw_query": "/**\n * @name Find dangerous code execution and deserialization\n * @description Finds calls to eval, exec, __import__, and pickle.load/loads\n * @kind problem\n * @problem.severity warning\n * @id py/dangerous-functions\n * @tags security\n *       external/cwe/cwe-094\n *       external/cwe/cwe-502\n */\n\nimport python\nimport semmle.python.ApiGraphs\n\nfrom DataFlow::CallCfgNode call\nwhere\n  (\n    call = API::builtin([\"eval\", \"exec\", \"__import__\"]).getACall() or\n    call = API::moduleImport(\"pickle\").getMember([\"load\", \"loads\"]).getACall() or\n    call = API::moduleImport(\"cPickle\").getMember([\"load\", \"loads\"]).getACall()\n  )\nselect call, \"Dangerous function call found.\"",
