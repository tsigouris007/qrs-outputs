      {
        "codeql_query_uuid": "20260118181732",
        "codeql_raw_query": "/**\n * @name Identify dangerous function calls details\n * @description Identifies the specific dangerous function being called and the enclosing function/method.\n * @kind problem\n * @problem.severity warning\n * @id py/dangerous-function-details\n * @tags security\n *       injection\n *       code-execution\n */\n\nimport python\nimport semmle.python.ApiGraphs\n\npredicate isDangerousFunction(string name) {\n  name in [\n    \"eval\",\n    \"exec\",\n    \"compile\",\n    \"__import__\"\n  ]\n}\n\nfrom DataFlow::CallCfgNode call, Function scope\nwhere\n  (\n    call = API::builtin(any(string name | isDangerousFunction(name))).getACall()\n  )\n  and scope = call.getScope()\nselect call, \"Dangerous call to \" + call.getFunction().asExpr().(Name).getId() + \" in \" + scope.getName()\n",
        "hypothesis": "Dangerous functions like eval or __import__ are used in constructors, potentially allowing arbitrary code execution if untrusted YAML is parsed.",
