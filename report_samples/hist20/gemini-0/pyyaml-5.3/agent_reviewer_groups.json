        "codeql_query_uuid": "20260118181834",
        "codeql_raw_query": "/**\n * @name Find callers of find_python_module and find_python_name\n * @description Traces usage of dynamic import helper functions\n * @kind problem\n * @problem.severity warning\n * @id py/trace-dynamic-imports\n * @tags security\n *       cwe-094\n */\n\nimport python\nimport semmle.python.ApiGraphs\n\nfrom Function f, Call c, Name n\nwhere\n  f.getName() in [\"find_python_module\", \"find_python_name\"]\n  and c.getScope() = f\n  and c.getFunc() = n\n  and n.getId() = \"__import__\"\nselect f, \"Function \" + f.getName() + \" calls __import__\"\n",
