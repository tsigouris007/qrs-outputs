      {
        "codeql_query_uuid": "20260118224516",
        "codeql_raw_query": "\n/**\n * @name Find update_into methods and from_buffer calls\n * @description Finds update_into methods and checks if they call from_buffer\n * @kind problem\n * @problem.severity warning\n * @id py/find-update-into-from-buffer\n * @tags security\n *       external/cwe/cwe-754\n */\n\nimport python\nimport semmle.python.ApiGraphs\n\nfrom Function f, Call c\nwhere\n  f.getName() = \"update_into\"\n  and c.getScope() = f\n  and c.getFunc().(Attribute).getName() = \"from_buffer\"\nselect f, \"Method 'update_into' calls 'from_buffer' at \" + c.getLocation().toString()\n",
        "hypothesis": "Methods named update_into that use from_buffer might be writing to the buffer without checking for writability.",
        "severity": "medium",
