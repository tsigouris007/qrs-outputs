      {
        "codeql_query_uuid": "20260118222527",
        "codeql_raw_query": "/**\n * @name Redirect Method Change Body Handling\n * @description Checks if the body is cleared when the method is changed to GET during a redirect.\n * @kind problem\n * @problem.severity warning\n * @id py/urllib3-redirect-body-handling\n * @tags security\n *       external/cwe/cwe-200\n */\n\nimport python\n\nfrom If i, AssignStmt assign, StrConst s\nwhere\n  // The if statement checks for a redirect status code (simplified check)\n  exists(Compare c | c = i.getTest() and\n    exists(Num n | n = c.getComparator(_) and n.getN().toString().regexpMatch(\"30[123]\"))\n  )\n  and\n  // Inside the if block (or else block, but usually if), there is an assignment\n  assign.getParent() = i.getBody()\n  and\n  // The assignment sets a variable to \"GET\"\n  assign.getValue() = s\n  and\n  s.getText() = \"GET\"\nselect i, \"Found redirect logic changing method to GET. Check if request body is cleared.\"\n",
        "hypothesis": "When redirecting and changing method to GET, the request body should be cleared to avoid sending sensitive data in the body of a GET request or confusing the server.",
        "severity": "medium",
        "cwe_ids": [
