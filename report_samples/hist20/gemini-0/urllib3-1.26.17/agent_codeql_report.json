      "codeql_raw_query": "/**\n * @name Find method assignment to GET\n * @description Finds assignments where a variable is set to 'GET', which might indicate a redirect method change.\n * @kind problem\n * @problem.severity warning\n * @id py/urllib3-method-get-assignment\n * @tags security\n *       external/cwe/cwe-200\n */\n\nimport python\nimport semmle.python.ApiGraphs\n\nfrom Assign a, StrConst s\nwhere\n  a.getValue() = s\n  and s.getText() = \"GET\"\nselect a, \"Assignment to 'GET' found.\"",
