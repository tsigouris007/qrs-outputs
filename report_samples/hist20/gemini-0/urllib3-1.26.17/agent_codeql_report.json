      "codeql_raw_query": "/**\n * @name Identify redirect handling logic\n * @description Locates code that handles HTTP redirect status codes (301, 302, 303, 307, 308)\n * @kind problem\n * @problem.severity recommendation\n * @id py/urllib3-redirect-logic\n * @tags security\n *       http\n *       redirect\n */\n\nimport python\nimport semmle.python.dataflow.new.DataFlow\n\nfrom DataFlow::Node node, int status\nwhere\n  (\n    node.asExpr().(IntegerLiteral).getValue() = status\n    or\n    node.asExpr().(Compare).getComparator(0).(IntegerLiteral).getValue() = status\n  )\n  and status in [301, 302, 303, 307, 308]\nselect node, \"Found reference to redirect status code: \" + status\n",
