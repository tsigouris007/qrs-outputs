      "codeql_raw_query": "/**\n * @name Identify context of int() calls in http_parser.py\n * @description Lists the function name and argument of int() calls in http_parser.py to understand their context.\n * @kind problem\n * @problem.severity note\n * @id py/aiohttp-int-context\n * @tags analysis\n */\n\nimport python\nimport semmle.python.ApiGraphs\n\nfrom Call c, Function f, Module m\nwhere\n  c.getScope() = f\n  and f.getEnclosingModule() = m\n  and m.getName().matches(\"%http_parser%\")\n  and c.getFunc().(Name).getId() = \"int\"\nselect c, \"int() called in function \" + f.getName() + \" with argument \" + c.getArg(0).toString()",
