      "codeql_raw_query": "/**\n * @name Header name stripping\n * @description Finds where header names might be stripped of whitespace, potentially violating RFC 9112\n * @kind problem\n * @problem.severity warning\n * @id py/aiohttp-header-strip\n * @tags security\n *       external/cwe/cwe-444\n */\n\nimport python\nimport semmle.python.dataflow.new.DataFlow\nimport semmle.python.ApiGraphs\n\nfrom DataFlow::CallCfgNode call\nwhere\n  call = API::builtin(\"str\").getMember([\"strip\", \"lstrip\", \"rstrip\"]).getACall()\nselect call, \"Potential stripping of whitespace which might mask invalid header formats.\"\n",
