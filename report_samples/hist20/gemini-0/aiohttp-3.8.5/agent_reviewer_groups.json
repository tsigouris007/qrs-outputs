        "codeql_raw_query": "/**\n * @name Header name stripping\n * @description Finds calls to strip/lstrip/rstrip in http_parser.py which might indicate incorrect header parsing\n * @kind problem\n * @problem.severity warning\n * @id py/aiohttp-header-strip-simple\n * @tags security\n *       external/cwe/cwe-444\n */\n\nimport python\nimport semmle.python.dataflow.new.DataFlow\n\nfrom DataFlow::CallCfgNode call, Attribute attr\nwhere\n  call.getFunction().asExpr() = attr and\n  attr.getName() in [\"strip\", \"lstrip\", \"rstrip\"] and\n  call.getLocation().getFile().getShortName() = \"http_parser.py\"\nselect call, \"Potential stripping of whitespace in header parser.\"\n",
