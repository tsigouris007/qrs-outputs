        "codeql_raw_query": "/**\n * @name Content-Length Validation Check\n * @description Checks if the argument to int() in get_content_length is validated using isdigit()\n * @kind problem\n * @problem.severity warning\n * @id py/aiohttp-content-length-validation\n * @tags security\n *       external/cwe/cwe-444\n */\n\nimport python\nimport semmle.python.dataflow.new.DataFlow\nimport semmle.python.ApiGraphs\n\nfrom DataFlow::CallCfgNode intCall, DataFlow::Node arg\nwhere\n  intCall = API::builtin(\"int\").getACall() and\n  intCall.getLocation().getFile().getShortName() = \"http_parser.py\" and\n  intCall.getLocation().getStartLine() = 326 and\n  arg = intCall.getArg(0) and\n  not exists(DataFlow::CallCfgNode isDigitCall |\n    isDigitCall.getFunction().(DataFlow::AttrRead).getAttributeName() = \"isdigit\" and\n    isDigitCall.getFunction().(DataFlow::AttrRead).getObject().getALocalSource() = arg.getALocalSource()\n  )\nselect intCall, \"int() called on potentially unvalidated input at line 326. Argument: \" + arg.toString()\n",
