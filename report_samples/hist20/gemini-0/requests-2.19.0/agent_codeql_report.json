      "codeql_raw_query": "/**\n * @name Inspect rebuild_auth condition\n * @description Inspects the condition of the If statement in rebuild_auth that guards the deletion of the Authorization header.\n * @kind problem\n * @problem.severity warning\n * @id py/inspect-rebuild-auth-condition\n * @tags security\n *       cwe-522\n */\n\nimport python\n\nfrom Function f, If i, Compare c\nwhere\n  f.getName() = \"rebuild_auth\"\n  and f.getAStmt() = i\n  and i.getTest() = c\n  and i.getLocation().getStartLine() = 245\nselect c, \"Condition: \" + c.toString()\n",
