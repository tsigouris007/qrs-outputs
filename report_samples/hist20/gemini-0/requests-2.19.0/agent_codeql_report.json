      "codeql_raw_query": "/**\n * @name Inspect rebuild_auth logic\n * @description Checks what attributes are accessed in rebuild_auth\n * @kind problem\n * @problem.severity warning\n * @id py/inspect-rebuild-auth\n * @tags security\n *       external/cwe/cwe-522\n */\n\nimport python\n\nfrom Function f, Attribute a\nwhere\n  f.getName() = \"rebuild_auth\"\n  and a.getScope() = f\n  and a.getName() in [\"scheme\", \"netloc\", \"host\", \"port\"]\nselect f, \"rebuild_auth accesses attribute: \" + a.getName()\n",
