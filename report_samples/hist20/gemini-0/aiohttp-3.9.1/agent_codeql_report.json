      "codeql_raw_query": "/**\n * @name Identify Static Resource Handling\n * @description Finds classes and methods related to static resource registration and handling in aiohttp\n * @kind problem\n * @problem.severity info\n * @id py/aiohttp-static-resource-handling\n * @tags analysis\n *       aiohttp\n */\n\nimport python\nimport semmle.python.ApiGraphs\n\nfrom Class c\nwhere\n    c.getName().matches(\"%StaticResource%\") or\n    c.getName().matches(\"%FileResponse%\")\nselect c, c.getName()\n",
