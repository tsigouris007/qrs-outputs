      "codeql_query_uuid": "20260118161028",
      "codeql_raw_query": "/**\n * @name Analyze StaticResource path resolution\n * @description Find methods in StaticResource that perform path manipulation\n * @kind problem\n * @problem.severity info\n * @id py/aiohttp-static-resource-path-resolution\n * @tags analysis\n */\n\nimport python\nimport semmle.python.ApiGraphs\n\nfrom Function f, Class c\nwhere\n  c.getName() = \"StaticResource\"\n  and f = c.getAMethod()\n  and (\n    exists(Call call |\n      call.getScope() = f\n      and (\n        call.getFunc().(Attribute).getName() in [\"join\", \"resolve\", \"normpath\", \"abspath\"]\n        or\n        call.getFunc().(Name).getId() = \"Path\"\n      )\n    )\n  )\nselect f, \"Method in StaticResource performing path manipulation\"\n",
