      "codeql_query_uuid": "20260118160937",
      "codeql_raw_query": "/**\n * @name Analyze StaticResource follow_symlinks\n * @description Inspects StaticResource class for follow_symlinks parameter handling\n * @kind problem\n * @problem.severity info\n * @id py/aiohttp-static-resource-symlinks\n * @tags security\n *       filesystem\n *       symlinks\n */\n\nimport python\nimport semmle.python.ApiGraphs\n\nfrom Class c, Function f\nwhere\n  c.getName() = \"StaticResource\"\n  and f = c.getMethod(\"__init__\")\nselect f, \"StaticResource.__init__ method\"",
