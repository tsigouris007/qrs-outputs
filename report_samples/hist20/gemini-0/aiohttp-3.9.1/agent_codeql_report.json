      "codeql_raw_query": "/**\n * @name Inspect resolve calls in StaticResource\n * @description Inspects how resolve() is called within StaticResource to check for symlink handling\n * @kind problem\n * @problem.severity warning\n * @id py/aiohttp-inspect-resolve\n * @tags security\n *       filesystem\n *       symlinks\n */\n\nimport python\nimport semmle.python.ApiGraphs\n\nfrom DataFlow::CallCfgNode call\nwhere\n  call = API::moduleImport(\"pathlib\").getMember(\"Path\").getMember(\"resolve\").getACall()\n  and call.getLocation().getFile().getShortName() = \"web_urldispatcher.py\"\nselect call, \"Call to resolve() found\"",
