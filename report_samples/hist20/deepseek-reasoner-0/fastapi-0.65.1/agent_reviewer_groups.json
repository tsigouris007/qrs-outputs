      {
        "codeql_query_uuid": "20260117184443",
        "codeql_raw_query": "/**\n * @name Analyze routing patterns for potential content-type issues\n * @description Look for patterns in routing.py that might indicate missing content-type validation\n * @kind problem\n * @problem.severity warning\n * @id py/routing-pattern-analysis\n * @tags security\n *        routing\n *        content-type\n */\n\nimport python\n\nfrom Call call, Attribute attr, Name name\nwhere\n  // Look for calls to json() on request objects\n  call.getFunc() = attr\n  and attr.getObject() = name\n  and name.getId() = \"request\"\n  and attr.getAttr() = \"json\"\n  and call.getLocation().getFile().getBaseName() = \"routing.py\"\nselect call, \"Request.json() call found in routing.py\"\n",
        "hypothesis": "Potential missing Content-Type validation before JSON parsing in request handlers",
