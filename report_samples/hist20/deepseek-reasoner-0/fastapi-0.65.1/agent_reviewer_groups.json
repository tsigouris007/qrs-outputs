        "codeql_query_uuid": "20260117184225",
        "codeql_raw_query": "/**\n * @name Find request body access patterns in routing\n * @description Find patterns where request body is accessed (json, body, form data)\n * @kind problem\n * @problem.severity note\n * @id py/request-body-access\n * @tags routing\n *       request\n *       security\n */\n\nimport python\n\nfrom Call call\nwhere \n  // Look for request.json() calls\n  (call.getFunc().(Attribute).getName() = \"json\" and \n   call.getFunc().(Attribute).getObject().(Name).getId() = \"request\") or\n  // Look for request.body() calls  \n  (call.getFunc().(Attribute).getName() = \"body\" and \n   call.getFunc().(Attribute).getObject().(Name).getId() = \"request\") or\n  // Look for request.form() calls\n  (call.getFunc().(Attribute).getName() = \"form\" and \n   call.getFunc().(Attribute).getObject().(Name).getId() = \"request\")\nselect call, \"Request body access: \" + call.toString()",
