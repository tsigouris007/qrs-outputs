      {
        "codeql_query_uuid": "20260117195228",
        "codeql_raw_query": "/**\n * @name Find from_buffer calls in cipher operations with context\n * @description Examines from_buffer calls in cipher-related files to understand usage patterns\n * @kind problem\n * @problem.severity recommendation\n * @id py/find-from-buffer-cipher-context\n * @tags security\n */\n\nimport python\n\nfrom Call c, Expr arg, string filename\nwhere\n  c.getFunc().(Attribute).getName() = \"from_buffer\"\n  and arg = c.getArg(0)\n  and filename = c.getLocation().getFile().getRelativePath()\n  and filename.matches(\"src/cryptography/hazmat/backends/openssl/ciphers.py\")\nselect c, \"from_buffer call with argument: \" + arg.toString() + \" at line \" + c.getLocation().getStartLine().toString()",
        "hypothesis": "Examine from_buffer calls in cipher operations to understand if buffer parameters are properly validated for writeability before write operations",
        "severity": "medium",
