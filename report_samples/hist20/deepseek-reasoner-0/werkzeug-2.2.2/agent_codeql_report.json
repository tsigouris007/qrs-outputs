      "codeql_raw_query": "/**\n * @name Find cookie parsing functions\n * @description Find functions that parse cookies in werkzeug package\n * @kind problem\n * @problem.severity recommendation\n * @id py/cookie-parsing-functions\n * @tags security\n *        validation\n */\n\nimport python\n\nfrom Function f, string name\nwhere\n  f.getName() = name and\n  (\n    name.matches(\"%cookie%\") or\n    name.matches(\"%Cookie%\") or\n    name.matches(\"%parse_cookie%\") or\n    name.matches(\"%parse_set_cookie%\")\n  )\nselect f, \"Cookie parsing function: \" + name",
