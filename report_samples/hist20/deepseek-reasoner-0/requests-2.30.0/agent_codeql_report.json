      "codeql_raw_query": "/**\n * @name Find security-relevant verb functions in requests\n * @description Finds all functions containing rebuild, reconstruct, proxy, resolve, auth and similar verbs\n * @kind problem\n * @problem.severity recommendation\n * @id py/find-security-relevant-verbs\n * @tags security\n *       functions\n *       verbs\n */\n\nimport python\n\nfrom Function f\nwhere f.getName().toLowerCase().matches(\"%rebuild%\")\n  or f.getName().toLowerCase().matches(\"%reconstruct%\")\n  or f.getName().toLowerCase().matches(\"%proxy%\")\n  or f.getName().toLowerCase().matches(\"%proxies%\")\n  or f.getName().toLowerCase().matches(\"%resolve%\")\n  or f.getName().toLowerCase().matches(\"%auth%\")\nselect f, \"Security-relevant function found: \" + f.getName()",
