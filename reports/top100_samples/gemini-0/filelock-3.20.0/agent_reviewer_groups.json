        "codeql_raw_query": "/**\n * @name Trace flags source for os.open\n * @description Traces the values flowing into the flags argument of os.open\n * @kind problem\n * @problem.severity info\n * @id py/trace-open-flags\n */\n\nimport python\nimport semmle.python.dataflow.new.DataFlow\nimport semmle.python.ApiGraphs\n\nfrom DataFlow::CallCfgNode call, DataFlow::Node flagArg, DataFlow::Node source\nwhere\n  call = API::moduleImport(\"os\").getMember(\"open\").getACall() and\n  flagArg = call.getArg(1) and\n  DataFlow::localFlow(source, flagArg) and\n  not source instanceof DataFlow::CallCfgNode and // Exclude intermediate calls if possible\n  not source = flagArg // Exclude self\nselect call, \"os.open called here\", source, \"Flag source: \" + source.toString()\n",
