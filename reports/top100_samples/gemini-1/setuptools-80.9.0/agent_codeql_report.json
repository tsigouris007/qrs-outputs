      "codeql_query_uuid": "20260101151456",
      "codeql_raw_query": "/**\n * @name Command Injection from Local Sources\n * @description Executing commands with input from command line or environment variables.\n * @kind path-problem\n * @problem.severity error\n * @id py/command-injection-local\n * @tags security\n *       external/cwe/cwe-078\n */\n\nimport python\nimport semmle.python.dataflow.new.DataFlow\nimport semmle.python.dataflow.new.TaintTracking\nimport semmle.python.ApiGraphs\nimport semmle.python.Concepts\n\nmodule LocalCommandInjectionConfig implements DataFlow::ConfigSig {\n  predicate isSource(DataFlow::Node source) {\n    // CLI arguments\n    source = API::moduleImport(\"sys\").getMember(\"argv\").asSource() or\n    // Environment variables\n    source = API::moduleImport(\"os\").getMember(\"environ\").asSource() or\n    source = API::moduleImport(\"os\").getMember(\"getenv\").getACall()\n  }\n\n  predicate isSink(DataFlow::Node sink) {\n    sink = any(SystemCommandExecution c).getCommand()\n  }\n}\n\nmodule LocalCommandInjectionFlow = TaintTracking::Global<LocalCommandInjectionConfig>;\nimport LocalCommandInjectionFlow::PathGraph\n\nfrom LocalCommandInjectionFlow::PathNode source, LocalCommandInjectionFlow::PathNode sink\nwhere LocalCommandInjectionFlow::flowPath(source, sink)\nselect sink.getNode(), source, sink, \"Command injection from $@.\", source.getNode(), \"local input\"\n",
