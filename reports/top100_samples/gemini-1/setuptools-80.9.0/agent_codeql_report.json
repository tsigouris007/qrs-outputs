      "codeql_query_uuid": "20260101151227",
      "codeql_raw_query": "/**\n * @name Subprocess calls with shell=True\n * @description Finds calls to subprocess with shell=True which might be vulnerable to command injection.\n * @kind problem\n * @problem.severity warning\n * @id py/subprocess-shell-true\n * @tags security\n *       external/cwe/cwe-078\n */\n\nimport python\nimport semmle.python.ApiGraphs\n\nfrom DataFlow::CallCfgNode call\nwhere\n  call = API::moduleImport(\"subprocess\").getMember([\"call\", \"check_call\", \"check_output\", \"run\", \"Popen\"]).getACall() and\n  call.getArgByName(\"shell\").asExpr().(BooleanLiteral).booleanValue() = true\nselect call, \"Subprocess call with shell=True.\"",
