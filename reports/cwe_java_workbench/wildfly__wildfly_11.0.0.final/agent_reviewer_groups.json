        "codeql_raw_query": "/**\n * @name Path traversal via WEB-INF or META-INF access check bypass\n * @description Checks if sensitive directories like WEB-INF and META-INF are protected using startsWith without canonicalization\n * @kind problem\n * @problem.severity error\n * @id java/sensitive-dir-startswith-check\n * @tags security\n *       external/cwe/cwe-022\n */\nimport java\n\nfrom MethodCall mc, StringLiteral sl\nwhere\n  mc.getMethod().hasName(\"startsWith\") and\n  mc.getMethod().getDeclaringType().hasQualifiedName(\"java.lang\", \"String\") and\n  sl.getValue().toLowerCase().regexpMatch(\".*(web-inf|meta-inf|webinf|metainf).*\") and\n  mc.getAnArgument() = sl\nselect mc, \"Sensitive directory check using startsWith() - may be bypassable: \" + sl.getValue()\n",
