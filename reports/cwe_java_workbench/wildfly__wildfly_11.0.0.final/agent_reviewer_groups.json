        "codeql_query_uuid": "20260326095813",
        "codeql_raw_query": "\n/**\n * @name ServletResourceManager path traversal via startsWith\n * @description Checks path containment using startsWith in resource serving without canonicalization\n * @kind problem\n * @problem.severity error\n * @id java/resource-manager-startswith\n * @tags security\n *       external/cwe/cwe-022\n */\nimport java\n\n// Find startsWith checks on path strings in resource serving classes\nfrom MethodCall startsWith, Method m\nwhere\n  startsWith.getMethod().hasName(\"startsWith\") and\n  startsWith.getMethod().getDeclaringType().hasQualifiedName(\"java.lang\", \"String\") and\n  m = startsWith.getEnclosingCallable() and\n  (\n    m.getDeclaringType().hasName(\"ServletResourceManager\") or\n    m.getDeclaringType().hasName(\"VirtualFileResource\") or\n    m.getDeclaringType().hasName(\"DelegatingResourceManager\")\n  ) and\n  // Not preceded by canonical path resolution\n  not exists(MethodCall canon |\n    (canon.getMethod().hasName(\"getCanonicalPath\") or\n     canon.getMethod().hasName(\"normalize\") or\n     canon.getMethod().hasName(\"toRealPath\")) and\n    canon.getEnclosingCallable() = m\n  )\nselect startsWith, \"Path containment via startsWith() without prior canonicalization in \" + m.getDeclaringType().getName() + \".\" + m.getName()\n",
