      {
        "codeql_query_uuid": "20260326095923",
        "codeql_raw_query": "\n/**\n * @name Path string used without normalization in security-sensitive contexts\n * @description Path strings with potential '..' sequences used without canonicalization\n * @kind problem\n * @problem.severity error\n * @id java/path-no-normalization\n * @tags security\n *       external/cwe/cwe-022\n */\nimport java\n\n// Find methods in security-sensitive file classes that use path strings but never normalize\nfrom Method m, MethodCall startsWith\nwhere \n  m.getDeclaringType().getQualifiedName().matches(\"org.wildfly.extension.undertow.%\") and\n  startsWith.getEnclosingCallable() = m and\n  startsWith.getMethod().hasName(\"startsWith\") and\n  startsWith.getMethod().getDeclaringType() instanceof TypeString and\n  // The qualifier/argument contains a path-like string\n  exists(string s | s = startsWith.getAnArgument().(StringLiteral).getValue() |\n    s.matches(\"%WEB-INF%\") or s.matches(\"%META-INF%\") or s = \"/\" or s.matches(\"%.%\")\n  ) and\n  // No canonical path call in the same method\n  not exists(MethodCall canon | \n    canon.getEnclosingCallable() = m and\n    (canon.getMethod().hasName(\"getCanonicalPath\") or \n     canon.getMethod().hasName(\"normalize\") or\n     canon.getMethod().hasName(\"toRealPath\"))\n  )\nselect startsWith, \"Path containment check via startsWith() in \" + m.getName() + \" without prior path normalization\"\n",
        "hypothesis": "Finding path containment checks using startsWith() without prior path normalization in security-sensitive undertow code",
