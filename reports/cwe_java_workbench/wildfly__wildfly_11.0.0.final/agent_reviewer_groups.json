        "codeql_raw_query": "/**\n * @name Path traversal in ServletResourceManager - startsWith without canonicalization\n * @description ServletResourceManager uses String.startsWith() for path containment without canonicalization\n * @kind problem\n * @problem.severity error\n * @id java/servlet-resource-manager-path-traversal\n * @tags security\n *       external/cwe/cwe-022\n */\nimport java\nimport semmle.code.java.dataflow.DataFlow\n\nfrom MethodCall startsWith, Method m\nwhere\n  startsWith.getMethod().hasName(\"startsWith\") and\n  startsWith.getQualifier().getType() instanceof TypeString and\n  startsWith.getEnclosingCallable().getDeclaringType().hasQualifiedName(\n    \"org.wildfly.extension.undertow.deployment\", \"ServletResourceManager\"\n  )\nselect startsWith, \"startsWith() path containment check in ServletResourceManager may be bypassable - path: \" + startsWith.getQualifier()\n",
