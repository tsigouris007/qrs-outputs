      {
        "codeql_query_uuid": "20260118145656",
        "codeql_raw_query": "/**\n * @name All from_buffer calls in cipher and AEAD operations\n * @description Comprehensive check for all from_buffer usage in cryptographic operations\n * @kind problem\n * @problem.severity warning\n * @id py/all-from-buffer-crypto-ops\n * @tags security\n *       external/cwe/cwe-754\n */\n\nimport python\n\nfrom Call fromBufferCall, Function func\nwhere\n  fromBufferCall.getFunc().(Attribute).getName() = \"from_buffer\" and\n  fromBufferCall.getScope() = func and\n  (\n    func.getName().matches(\"%decrypt%\") or\n    func.getName().matches(\"%encrypt%\") or\n    func.getName().matches(\"%update%\") or\n    func.getName().matches(\"%finalize%\")\n  ) and\n  func.getLocation().getFile().getRelativePath().matches(\"%hazmat/backends/openssl/%\")\nselect fromBufferCall, \"from_buffer call in cryptographic operation \" + func.getName() + \" at \" + fromBufferCall.getLocation().getFile().getRelativePath()",
        "hypothesis": "Identify all from_buffer calls in cryptographic operations to ensure comprehensive coverage of potential buffer writeability issues",
