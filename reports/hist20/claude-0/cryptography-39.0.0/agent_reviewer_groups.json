        "codeql_raw_query": "/**\n * @name Methods with from_buffer that may write to buffers without writeability checks\n * @description Identifies methods that use from_buffer on parameters and may write to them\n * @kind problem\n * @problem.severity warning\n * @id py/buffer-writeability-check\n * @tags security\n *       external/cwe/cwe-754\n */\n\nimport python\nimport semmle.python.dataflow.new.DataFlow\n\nfrom Function func, Call fromBufferCall, Parameter param\nwhere\n  fromBufferCall.getFunc().(Attribute).getName() = \"from_buffer\" and\n  fromBufferCall.getScope() = func and\n  func.getName().matches(\"%into%\") and\n  param = func.getAnArg()\nselect func, \"Method \" + func.getName() + \" uses from_buffer on parameter that may be written to without writeability validation\"",
