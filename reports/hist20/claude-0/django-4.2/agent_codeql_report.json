      "codeql_raw_query": "/**\n * @name Find potentially vulnerable regex patterns with nested quantifiers\n * @description Identifies regex patterns with nested quantifiers that could lead to catastrophic backtracking\n * @kind problem\n * @problem.severity error\n * @id py/regex-nested-quantifiers\n * @tags security\n *       external/cwe/cwe-1333\n *       external/cwe/cwe-400\n */\n\nimport python\n\nfrom StrConst pattern\nwhere\n  pattern.getEnclosingModule().getName() = \"django.core.validators\" and\n  (\n    // Look for patterns with nested quantifiers like (x+)+ or (x*)*\n    pattern.getText().regexpMatch(\".*\\\\([^)]*[+*]\\\\)[+*].*\") or\n    // Look for patterns with alternation and quantifiers\n    pattern.getText().regexpMatch(\".*\\\\([^)]*\\\\|[^)]*\\\\)[+*].*\") or\n    // Look for patterns with .+ or .* combined with other quantifiers\n    pattern.getText().regexpMatch(\".*\\\\.\\\\+.*[+*].*\") or\n    pattern.getText().regexpMatch(\".*\\\\.\\\\*.*[+*].*\")\n  )\nselect pattern, \"Potentially vulnerable regex pattern with nested quantifiers: \" + pattern.getText()",
