      "codeql_raw_query": "/**\n * @name ReDoS vulnerability in domain label validation\n * @description Domain validation that iterates over labels without bounds and applies regex can cause ReDoS\n * @kind problem\n * @problem.severity error\n * @id py/redos-domain-label-validation\n * @tags security\n *       external/cwe/cwe-1333\n *       external/cwe/cwe-400\n */\n\nimport python\n\nfrom For loop, Call call\nwhere\n  loop.getScope().getName() = \"validate_domain_part\" and\n  call.getScope() = loop.getScope() and\n  exists(Attribute attr | \n    attr = call.getFunc() and \n    (attr.getName() = \"match\" or attr.getName() = \"search\" or attr.getName() = \"fullmatch\")\n  )\nselect loop, \"Domain validation loop that applies regex to each label without input size limits, potentially causing ReDoS with many labels\"\n",
