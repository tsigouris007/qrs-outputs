      {
        "codeql_query_uuid": "20260118140714",
        "codeql_raw_query": "/**\n * @name Command execution in VCS download functions\n * @description Identifies subprocess calls in VCS download functions that may be vulnerable to command injection\n * @kind problem\n * @problem.severity error\n * @id py/vcs-command-execution\n * @tags security\n *       external/cwe/cwe-078\n */\n\nimport python\nimport semmle.python.ApiGraphs\n\nfrom DataFlow::CallCfgNode call, Function func\nwhere\n  // Find subprocess calls\n  (\n    call = API::moduleImport(\"subprocess\").getMember([\"call\", \"check_call\", \"run\", \"Popen\"]).getACall() or\n    call = API::moduleImport(\"os\").getMember(\"system\").getACall()\n  ) and\n  // Within VCS download functions\n  func = call.getScope() and\n  (\n    func.getName().matches(\"%download%\") or\n    func.getName().matches(\"%vcs%\") or\n    func.getName() in [\"_download_svn\", \"_download_git\", \"_download_hg\"]\n  ) and\n  func.getLocation().getFile().getBaseName() = \"package_index.py\"\nselect call, \"Subprocess call in VCS download function: \" + func.getName() + \" at line \" + call.getLocation().getStartLine().toString()\n",
        "hypothesis": "VCS download functions (_download_svn, _download_git, _download_hg) may execute subprocess commands with URLs that could contain shell metacharacters, leading to command injection",
        "severity": "high",
        "cwe_ids": [
          "cwe-78",
          "cwe-94"
        ],
        "results_count": 4,
