        "codeql_query_uuid": "20260118141102",
        "codeql_raw_query": "/**\n * @name Subprocess calls with shell=True\n * @description Find subprocess calls using shell=True which can lead to command injection\n * @kind problem\n * @problem.severity error\n * @id py/subprocess-shell-true\n * @tags security\n *        external/cwe/cwe-078\n */\n\nimport python\nimport semmle.python.ApiGraphs\nimport semmle.python.dataflow.new.DataFlow\n\nfrom DataFlow::CallCfgNode call\nwhere\n  (\n    call = API::moduleImport(\"subprocess\").getMember([\"call\", \"check_call\", \"run\", \"Popen\"]).getACall() or\n    call = API::moduleImport(\"os\").getMember(\"system\").getACall()\n  ) and\n  (\n    // Check for shell=True keyword argument\n    exists(DataFlow::Node arg |\n      arg = call.getArgByName(\"shell\") and\n      arg.asExpr().(BooleanLiteral).booleanValue() = true\n    ) or\n    // os.system always uses shell\n    call = API::moduleImport(\"os\").getMember(\"system\").getACall()\n  )\nselect call, \"Subprocess call with shell=True at \" + call.getLocation().getFile().getBaseName() + \":\" + call.getLocation().getStartLine().toString()",
