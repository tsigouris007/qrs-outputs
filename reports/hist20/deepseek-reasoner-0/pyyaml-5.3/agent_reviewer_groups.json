        "codeql_raw_query": "/**\n * @name Find dangerous code execution methods\n * @description Finds all calls to eval, exec, compile, and __import__ functions\n * @kind problem\n * @problem.severity warning\n * @id py/find-dangerous-code-execution\n * @tags security\n *       injection\n *       code-execution\n */\n\nimport python\nimport semmle.python.ApiGraphs\n\nfrom DataFlow::CallCfgNode call\nwhere\n  call = API::builtin(\"eval\").getACall() or\n  call = API::builtin(\"exec\").getACall() or\n  call = API::builtin(\"compile\").getACall() or\n  call = API::builtin(\"__import__\").getACall()\nselect call, \"Dangerous code execution function found\"\n",
