        "codeql_raw_query": "/**\n * @name Content-Length parsing in HTTP parser\n * @description Look for Content-Length header parsing patterns in http_parser.py\n * @kind problem\n * @problem.severity warning\n * @id py/content-length-http-parser\n * @tags security\n *        external/cwe/cwe-444\n */\n\nimport python\n\nfrom Call call\nwhere\n  // Look for calls in the http_parser.py file\n  call.getLocation().getFile().getRelativePath() = \"aiohttp/http_parser.py\" and\n  (\n    // Look for int() calls\n    exists(Name n | n = call.getFunc() and n.getId() = \"int\") or\n    // Look for isdigit() calls\n    (call.getFunc().(Attribute).getName() = \"isdigit\") or\n    // Look for Content-Length related code\n    exists(string s | s = call.toString() and s.toUpperCase().matches(\"%CONTENT-LENGTH%\"))\n  )\nselect call, \"Content-Length parsing related call found in HTTP parser\"",
        "hypothesis": "Content-Length header parsing may have RFC violations in the HTTP parser",
