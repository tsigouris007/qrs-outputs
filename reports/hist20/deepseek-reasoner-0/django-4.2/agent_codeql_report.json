      "codeql_raw_query": "/**\n * @name Find regex patterns in Django validators and forms\n * @description Locates regular expression patterns used in Django validation\n * @kind problem\n * @problem.severity note\n * @id py/django-regex-patterns\n * @tags regex validation\n */\n\nimport python\nimport semmle.python.ApiGraphs\n\n// Find re.compile calls\nfrom DataFlow::CallCfgNode compileCall\nwhere \n  compileCall = API::moduleImport(\"re\").getMember(\"compile\").getACall()\nselect compileCall, \"re.compile() call found\"",
