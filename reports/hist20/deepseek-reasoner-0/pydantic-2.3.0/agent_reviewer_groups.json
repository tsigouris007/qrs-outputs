      {
        "codeql_query_uuid": "20260117165919",
        "codeql_raw_query": "/**\n * @name Email validation function analysis\n * @description Analyze email validation functions for missing length checks before regex\n * @kind problem\n * @problem.severity warning\n * @id py/email-validation-length-check\n * @tags security\n *        external/cwe/cwe-1333\n */\n\nimport python\n\n// Find functions that validate email addresses\nfrom Function func, string funcName\nwhere \n  funcName = func.getName()\n  and (\n    funcName.regexpMatch(\"(?i).*email.*validat.*\") or\n    funcName.regexpMatch(\"(?i)validat.*email.*\") or\n    funcName = \"validate_email\" or\n    funcName = \"is_valid_email\"\n  )\nselect func, \"Email validation function found: \" + funcName",
