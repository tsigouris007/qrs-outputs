        "codeql_query_uuid": "20260117181315",
        "codeql_raw_query": "/**\n * @name Find command execution in package_index.py\n * @description Finds command execution calls in the package_index module\n * @kind problem\n * @problem.severity warning\n * @id py/command-execution-package-index\n * @tags security\n *        command-injection\n */\n\nimport python\nimport semmle.python.ApiGraphs\n\nfrom DataFlow::CallCfgNode call\nwhere\n  // Look for subprocess calls\n  call = API::moduleImport(\"subprocess\").getMember([\"call\", \"run\", \"Popen\", \"check_call\", \"check_output\"]).getACall()\n  and call.getLocation().getFile().getBaseName() = \"package_index.py\"\n  // Or os.system calls\n  or call = API::moduleImport(\"os\").getMember(\"system\").getACall()\n  and call.getLocation().getFile().getBaseName() = \"package_index.py\"\nselect call, \"Command execution call in package_index.py: \" + call.toString()",
