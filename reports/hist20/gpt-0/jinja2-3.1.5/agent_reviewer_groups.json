        "codeql_query_uuid": "20260118014717",
        "codeql_raw_query": "/**\n * @name Jinja2 sandbox and filter related files\n * @description Locate sandbox, filter, and attr-related constructs for further manual review.\n * @kind problem\n * @problem.severity recommendation\n * @id py/jinja2-sandbox-filter-attr-overview\n * @tags security\n *       sandbox\n *       filters\n */\n\nimport python\n\nfrom File f\nwhere\n  f.getBaseName().toLowerCase().matches(\"%sandbox%\") or\n  f.getBaseName().toLowerCase().matches(\"%filter%\") or\n  f.getBaseName().toLowerCase().matches(\"%runtime%\") or\n  f.getBaseName().toLowerCase().matches(\"%environment%\")\nselect f, \"Security-relevant file: \" + f.getBaseName()",
        "hypothesis": "Identify core sandbox, filter, runtime, and environment modules as starting points for deeper analysis.",
