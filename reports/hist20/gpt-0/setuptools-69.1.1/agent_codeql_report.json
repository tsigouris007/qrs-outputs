      "codeql_raw_query": "/**\n * @name Shell command execution in setuptools\n * @description Find uses of os.system, os.popen, and subprocess with shell=True in setuptools core modules.\n * @kind problem\n * @problem.severity warning\n * @id py/shell-exec-setuptools\n * @tags security\n *       external/cwe/cwe-078\n */\n\nimport python\nimport semmle.python.ApiGraphs\nimport semmle.python.dataflow.new.DataFlow\n\nfrom DataFlow::CallCfgNode call, string kind\nwhere\n  call.getLocation().getFile().getRelativePath().matches(\"setuptools/%\") and\n  (\n    call = API::moduleImport(\"os\").getMember([\"system\", \"popen\"]).getACall() and kind = \"os-shell\" or\n    call = API::moduleImport(\"subprocess\").getMember([\"Popen\", \"call\", \"run\", \"check_call\", \"check_output\"]).getACall() and kind = \"subprocess\"\n  )\nselect call, \"Shell command execution (\" + kind + \") in setuptools core module.\"",
