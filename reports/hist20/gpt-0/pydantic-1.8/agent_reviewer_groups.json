        "codeql_raw_query": "/**\n * @name Numeric arguments to datetime/timedelta in pydantic.datetime_parse\n * @description Locate calls in datetime_parse.py where numeric values are passed to datetime/timedelta constructors\n * @kind problem\n * @problem.severity warning\n * @id py/pydantic/datetime-numeric-args\n * @tags security\n *       external/cwe/cwe-835\n *       external/cwe/cwe-400\n */\n\nimport python\n\nfrom Call call, Expr arg\nwhere\n  call.getLocation().getFile().getRelativePath() = \"pydantic/datetime_parse.py\" and\n  arg = call.getAnArg() and\n  arg instanceof Num\nselect call, \"Call with numeric literal argument in datetime_parse.py; review for missing bounds/inf handling.\"\n",
