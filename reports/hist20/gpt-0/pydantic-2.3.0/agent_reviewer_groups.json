        "codeql_query_uuid": "20260118022124",
        "codeql_raw_query": "/**\n * @name Find regex operations in pydantic email/network modules\n * @description Finds regex operations in pydantic modules likely related to email or network validation.\n * @kind problem\n * @problem.severity recommendation\n * @id py/pydantic-find-regex-operations\n * @tags regex\n *       validation\n *       security\n *       external/cwe/cwe-1333\n */\n\nimport python\n\npredicate isRegexMethod(string name) {\n  name in [\n    \"compile\",\n    \"match\",\n    \"search\",\n    \"findall\",\n    \"finditer\",\n    \"sub\",\n    \"subn\",\n    \"split\",\n    \"fullmatch\"\n  ]\n}\n\nfrom Call c, string methodName, string filePath\nwhere\n  c.getFunc().(Attribute).getName() = methodName and\n  c.getFunc().(Attribute).getObject().(Name).getId() = \"re\" and\n  isRegexMethod(methodName) and\n  filePath = c.getLocation().getFile().getRelativePath() and\n  filePath.regexpMatch(\"pydantic/(networks|types|validators|deprecated/.*|v1/networks)\\\\.py\")\nselect c, \"Regex operation found in \" + filePath + \": re.\" + methodName + \"()\"",
        "hypothesis": "Locate regex usage in pydantic email/network-related modules as a precursor to identifying potential ReDoS in email validation.",
        "severity": "medium",
        "cwe_ids": [
          "cwe-1333"
        ],
