      "codeql_raw_query": "/**\n * @name Find float conversions in datetime_parse.py\n * @description Finds calls to float() in pydantic/datetime_parse.py to identify potential infinity handling issues.\n * @kind problem\n * @problem.severity warning\n * @id py/float-conversions-datetime-parse\n * @tags security\n *       external/cwe/cwe-835\n *       external/cwe/cwe-400\n */\n\nimport python\nimport semmle.python.dataflow.new.DataFlow\nimport semmle.python.ApiGraphs\n\nfrom DataFlow::CallCfgNode call\nwhere\n  call.getLocation().getFile().getShortName() = \"datetime_parse.py\" and\n  call = API::builtin(\"float\").getACall()\nselect call, \"Call to float() found in datetime_parse.py\"\n",
