      "codeql_query_uuid": "20260118223110",
      "codeql_raw_query": "/**\n * @name Find regex patterns in http.py\n * @description Extracts the actual regex pattern strings from re module calls in werkzeug/http.py\n * @kind problem\n * @problem.severity recommendation\n * @id py/find-http-regex-patterns\n * @tags regex\n *       security\n *       validation\n */\n\nimport python\nimport semmle.python.ApiGraphs\n\nfrom DataFlow::CallCfgNode call, string pattern\nwhere\n  call = API::moduleImport(\"re\").getMember([\"compile\", \"match\", \"search\", \"findall\", \"finditer\", \"sub\", \"subn\", \"split\", \"fullmatch\"]).getACall()\n  and call.getLocation().getFile().getShortName() = \"http.py\"\n  and (\n    pattern = call.getArg(0).asExpr().(StrConst).getText()\n    or\n    exists(DataFlow::Node node | node = call.getArg(0) and node.asExpr().(Name).getId() = pattern) \n  )\nselect call, \"Regex pattern used: \" + pattern\n",
