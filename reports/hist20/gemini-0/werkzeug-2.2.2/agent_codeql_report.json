    {
      "codeql_query_uuid": "20260118223136",
      "codeql_raw_query": "/**\n * @name Analyze parse_cookie\n * @description Find parse_cookie function and regexes used within it\n * @kind problem\n * @problem.severity info\n * @id py/analyze-parse-cookie\n * @tags analysis\n *       cookie\n */\n\nimport python\nimport semmle.python.ApiGraphs\n\nfrom Function f, Call c, StrConst pattern\nwhere\n  f.getName() = \"parse_cookie\"\n  and c.getScope() = f\n  and c.getFunc().(Attribute).getObject().(Name).getId() = \"re\"\n  and pattern = c.getArg(0)\nselect f, \"parse_cookie uses regex: \" + pattern.getText()\n",
