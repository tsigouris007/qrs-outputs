        "codeql_raw_query": "/**\n * @name Redirect and Auth Header Handling\n * @description Identify code that handles redirects and manipulates Authorization headers\n * @kind problem\n * @problem.severity recommendation\n * @id py/requests-redirect-auth\n * @tags security\n *       external/cwe/cwe-522\n */\n\nimport python\nimport semmle.python.ApiGraphs\n\nfrom Function f, Return ret\nwhere\n  f.getName() = \"rebuild_auth\" or\n  f.getName() = \"resolve_redirects\" or\n  (\n    f.getName() = \"send\" and\n    f.getEnclosingModule().getName().matches(\"%sessions%\")\n  )\nselect f, \"Function potentially involved in redirect/auth handling\"\n",
