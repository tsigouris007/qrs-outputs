        "codeql_raw_query": "/**\n * @name Inspect rebuild_auth comparison attributes\n * @description Identifies the specific attributes being compared in rebuild_auth\n * @kind problem\n * @problem.severity info\n * @id py/inspect-rebuild-auth-attributes\n * @tags security\n *       analysis\n */\n\nimport python\n\nfrom Function f, If i, Compare c, Attribute left, Attribute right\nwhere\n  f.getName() = \"rebuild_auth\"\n  and i.getScope() = f\n  and c = i.getTest()\n  and c.getOp(0) instanceof NotEq\n  and left = c.getLeft()\n  and right = c.getComparator(0)\nselect c, \"Comparing \" + left.getObject().(Name).getId() + \".\" + left.getName() + \" != \" + right.getObject().(Name).getId() + \".\" + right.getName()\n",
