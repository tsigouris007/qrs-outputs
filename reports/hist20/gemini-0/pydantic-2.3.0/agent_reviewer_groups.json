        "codeql_raw_query": "/**\n * @name Extract Regex Patterns in networks.py\n * @description Extracts regex patterns used in pydantic/networks.py and pydantic/v1/networks.py\n * @kind problem\n * @problem.severity warning\n * @id py/pydantic-extract-regex\n * @tags security\n *       external/cwe/cwe-1333\n */\n\nimport python\nimport semmle.python.dataflow.new.DataFlow\nimport semmle.python.ApiGraphs\n\nfrom DataFlow::CallCfgNode call\nwhere\n  call.getLocation().getFile().getShortName() in [\"networks.py\"] and\n  (\n    call = API::moduleImport(\"re\").getMember([\"compile\", \"match\", \"search\", \"fullmatch\", \"findall\", \"finditer\", \"sub\", \"split\"]).getACall()\n  )\nselect call, \"Regex call found. Arg 0: \" + call.getArg(0).asExpr().(StrConst).getText()\n",
