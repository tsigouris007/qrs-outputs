      {
        "codeql_query_uuid": "20260118171615",
        "codeql_raw_query": "/**\n * @name Check for missing formaction in link_attrs\n * @description Checks if 'formaction' is missing from link_attrs in lxml.html.defs, which could allow XSS via javascript: URLs in formaction attributes.\n * @kind problem\n * @problem.severity high\n * @id py/lxml-missing-formaction\n * @tags security\n *       xss\n *       sanitization\n *       cwe-079\n */\n\nimport python\n\npredicate isLinkAttrs(Assign a) {\n  exists(Name n |\n    a.getTargets().getAnItem() = n\n    and n.getId() = \"link_attrs\"\n  )\n}\n\npredicate containsFormAction(Expr e) {\n  exists(Str s |\n    // Direct string in list/set/tuple\n    (\n      s = e.(List).getAnElt() or\n      s = e.(Tuple).getAnElt() or\n      s = e.(Set).getAnElt()\n    )\n    and s.getS() = \"formaction\"\n  )\n  or\n  exists(Call c |\n    // set([...])\n    c = e\n    and c.getFunc().(Name).getId() = \"set\"\n    and containsFormAction(c.getArg(0))\n  )\n}\n\nfrom Assign a\nwhere\n  isLinkAttrs(a)\n  and not containsFormAction(a.getValue())\nselect a, \"link_attrs definition missing 'formaction' attribute.\"\n",
        "hypothesis": "Missing formaction in link_attrs allows XSS via javascript: URLs",
        "severity": "high",
        "cwe_ids": [
          "CWE-79"
        ],
