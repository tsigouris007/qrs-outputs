        "codeql_raw_query": "/**\n * @name Trace pickle input in bccache\n * @description Traces the source of data entering pickle.load in bccache.py\n * @kind path-problem\n * @problem.severity error\n * @id py/bccache-pickle-trace\n * @tags security\n *       external/cwe/cwe-502\n */\n\nimport python\nimport semmle.python.dataflow.new.DataFlow\nimport semmle.python.dataflow.new.TaintTracking\nimport semmle.python.ApiGraphs\n\nmodule PickleFlowConfig implements DataFlow::ConfigSig {\n  predicate isSource(DataFlow::Node source) {\n    // Consider any parameter or file read as a potential source for now to see where it comes from\n    source instanceof DataFlow::ParameterNode or\n    source = any(DataFlow::CallCfgNode call | \n      call = API::builtin(\"open\").getACall()\n    )\n  }\n\n  predicate isSink(DataFlow::Node sink) {\n    exists(DataFlow::CallCfgNode call |\n      call = API::moduleImport(\"pickle\").getMember([\"load\", \"loads\"]).getACall() and\n      sink = call.getArg(0) and\n      call.getLocation().getFile().getBaseName() = \"bccache.py\"\n    )\n  }\n}\n\nmodule PickleFlow = TaintTracking::Global<PickleFlowConfig>;\nimport PickleFlow::PathGraph\n\nfrom PickleFlow::PathNode source, PickleFlow::PathNode sink\nwhere PickleFlow::flowPath(source, sink)\nselect sink.getNode(), source, sink, \"Pickle data source: $@.\", source.getNode(), \"source\"\n",
